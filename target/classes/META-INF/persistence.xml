<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    version="3.0" 
    xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    
    <persistence-unit name="BibliotecaComponentes-PU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <!-- Lista de Entidades de Engenharia -->
        <class>com.arcosprojetos.model.Familia</class>
        <class>com.arcosprojetos.model.Categoria</class>
        <class>com.arcosprojetos.model.Classe</class>
        <class>com.arcosprojetos.model.Tipo</class>
        <class>com.arcosprojetos.model.Subtipo</class>
        <class>com.arcosprojetos.model.Componente</class>
        <class>com.arcosprojetos.model.AtributoTecnico</class>
        <!-- Lista de Entidades de Acesso -->
        <class>com.arcosprojetos.model.Usuario</class>

        <properties>
            <!-- Configurações de Conexão com o Banco de Dados -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/biblioteca_de_componentes?useSSL=false&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="Amidamaru11"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <!-- Configurações do Hibernate -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            
            <!-- enquanto você está criando tabelas ainda, pode usar update. quando estabilizar, volte para validate -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>

